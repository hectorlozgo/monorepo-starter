{
  "name": "server",
  "version": "0.1.0",
  "description": "backend initial project",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node --import tsx dist/index.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "prettier": "prettier . --write",
    "lint": "eslint . --fix",
    "format": "prettier . --write && eslint . --fix",
    "test": "jest",
    "coverage": "jest --coverage",
    "clean": "rimraf dist coverage",
    "clean:logs": "rimraf logs"
  },
  "author": "Hector Lozano",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "http-errors": "2.0.1",
    "pino": "10.3.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/http-errors": "2.0.5",
    "@types/jest": "30.0.0",
    "@types/supertest": "6.0.3",
    "cross-env": "10.1.0",
    "jest": "30.2.0",
    "jiti": "2.6.1",
    "lint-staged": "16.2.7",
    "pino-pretty": "13.1.3",
    "rimraf": "6.1.2",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6"
  }
}
