{
  "name": "fullstack-boilerplate",
  "version": "1.0.0",
  "description": "monorepo boilerplate for fullstack applications",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "npm run build --workspace server",
    "start": "npm run start --workspace server",
    "dev": "npm run dev --workspace server",
    "lint": "npm run lint --workspace server",
    "prettier": "npm run prettier --workspace server",
    "format": "npm run format --workspace server",
    "test": "npm run test --workspace server",
    "coverage": "npm run coverage --workspace server",
    "clean": "npm run clean --workspace server",
    "clean:logs": "npm run clean:logs --workspace server",
    "prepare": "husky"
  },
  "workspaces": [
    "server"
  ],
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "keywords": [
    "boilerplate",
    "fullstack",
    "monorepo",
    "api-rest",
    "restful",
    "express",
    "react",
    "node",
    "typescript"
  ],
  "author": "Hector Lozano",
  "license": "ISC",
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@commitlint/types": "20.3.1",
    "husky": "9.1.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
